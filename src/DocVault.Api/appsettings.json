{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=docvault;Username=docvault;Password=docvault",
    "AzureBlob": ""
  },
  "Auth": {
    "JwtSigningKey": "vVPSA0Ol+UkJnKvKIrOAzgL+RdI+zUYo7S7uqZ49PltjLwzKenabNqlYs/1aj4PD",
    "JwtIssuer": "docvault",
    "JwtAudience": "docvault-ui",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7,
    "AdminEmail": "admin@docvault.local",
    "AdminPassword": "Admin1234!"
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "text-embedding-3-small",
    "BaseUrl": "https://api.openai.com/v1",
    "Dimensions": 1536,
    "MaxInputCharacters": 6000,
    "MaxBatchSize": 8
  },
  "QA": {
    "Model": "llama3.1",
    "MaxTokens": 250
  },
  "Resilience": {
    "Embedding": {
      "AttemptTimeoutSeconds": 15,
      "TotalTimeoutSeconds": 60,
      "MaxRetryAttempts": 3
    },
    "Qa": {
      "AttemptTimeoutSeconds": 90,
      "TotalTimeoutSeconds": 300,
      "MaxRetryAttempts": 2
    }
  },
  "RateLimit": {
    "DocumentUploadPerMinute": 6000
  },
  "Upload": {
    "MaxFileSizeBytes": 52428800,
    "MaxUploadCount": 10
  },
  "IndexingWorker": {
    "MaxDegreeOfParallelism": 4
  },
  "EmbeddingCache": {
    "IsEnabled": true,
    "MaxEntries": 10000,
    "SlidingExpirationMinutes": 60
  },
  "Storage": {
    "ContainerName": "docvault"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "DocVault": "Information"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}\n     {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext}\n     {Message:lj} {Properties:j}\n{Exception}",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ]
  }
}
