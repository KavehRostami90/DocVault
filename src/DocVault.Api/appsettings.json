{
  "ConnectionStrings": {
    "Database": "",
    "AzureBlob": ""
  },
  "Auth": {
    "Authority": "",
    "Audience": ""
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "text-embedding-3-small",
    "BaseUrl": "https://api.openai.com/v1",
    "Dimensions": 1536
  },
  "Storage": {
    "ContainerName": "docvault"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Formatting.Compact" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "DocVault": "Information"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}\n     {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.clef",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ]
  }
}
