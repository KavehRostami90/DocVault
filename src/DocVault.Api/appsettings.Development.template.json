{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=docvault;Username=docvault;Password=docvault",
    "AzureBlob": ""
  },
  "Auth": {
    "JwtSigningKey": "<min-32-char-secret>",
    "JwtIssuer": "docvault",
    "JwtAudience": "docvault-ui",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7,
    "AdminEmail": "<admin-email>",
    "AdminPassword": "<admin-password>"
  },
  "OpenAI": {
  "ApiKey": "ollama",
  "BaseUrl": "http://localhost:11434/v1",
  "Model": "nomic-embed-text",
  "Dimensions": 768,
  "MaxInputCharacters": 6000,
  "MaxBatchSize": 8
  },
  "Storage": {
    "BasePath": "storage"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:5173"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Information",
        "DocVault": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}\n     {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "C:\\Logs\\DocVault\\log-.log",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext}\n     {Message:lj} {Properties:j}\n{Exception}",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ]
  }
}
