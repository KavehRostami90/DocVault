{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Server=#{DATABASE_HOST}#;Database=#{DATABASE_NAME}#;User Id=#{DATABASE_USER}#;Password=#{DATABASE_PASSWORD}#;Port=5432;SSL Mode=Require;Trust Server Certificate=true;",
    "Redis": "#{REDIS_CONNECTION_STRING}#"
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Process",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/docvault-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "#{SEQ_URL}#",
          "apiKey": "#{SEQ_API_KEY}#"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithProcessId",
      "WithProcessName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "DocVault",
      "Environment": "#{ENVIRONMENT}#"
    }
  },
  "Search": {
    "Provider": "Elasticsearch",
    "Elasticsearch": {
      "Uri": "#{ELASTICSEARCH_URI}#",
      "IndexName": "#{ELASTICSEARCH_INDEX}#",
      "Username": "#{ELASTICSEARCH_USERNAME}#",
      "Password": "#{ELASTICSEARCH_PASSWORD}#"
    },
    "AzureCognitive": {
      "ServiceName": "#{AZURE_SEARCH_SERVICE_NAME}#",
      "AdminKey": "#{AZURE_SEARCH_ADMIN_KEY}#",
      "QueryKey": "#{AZURE_SEARCH_QUERY_KEY}#",
      "IndexName": "#{AZURE_SEARCH_INDEX}#"
    }
  },
  "AI": {
    "Provider": "OpenAI",
    "OpenAI": {
      "ApiKey": "#{OPENAI_API_KEY}#",
      "Model": "text-embedding-3-large",
      "BaseUrl": "https://api.openai.com/v1"
    },
    "AzureOpenAI": {
      "Endpoint": "#{AZURE_OPENAI_ENDPOINT}#",
      "ApiKey": "#{AZURE_OPENAI_API_KEY}#",
      "DeploymentName": "#{AZURE_OPENAI_DEPLOYMENT}#"
    }
  },
  "Storage": {
    "Provider": "AzureBlob",
    "AzureBlob": {
      "ConnectionString": "#{AZURE_STORAGE_CONNECTION_STRING}#",
      "ContainerName": "#{AZURE_STORAGE_CONTAINER}#"
    },
    "S3": {
      "BucketName": "#{S3_BUCKET_NAME}#",
      "Region": "#{S3_REGION}#",
      "AccessKey": "#{S3_ACCESS_KEY}#",
      "SecretKey": "#{S3_SECRET_KEY}#"
    }
  },
  "Messaging": {
    "Provider": "ServiceBus",
    "ServiceBus": {
      "ConnectionString": "#{SERVICE_BUS_CONNECTION_STRING}#",
      "QueueName": "#{SERVICE_BUS_QUEUE_NAME}#"
    },
    "RabbitMQ": {
      "HostName": "#{RABBITMQ_HOSTNAME}#",
      "Port": 5672,
      "UserName": "#{RABBITMQ_USERNAME}#",
      "Password": "#{RABBITMQ_PASSWORD}#",
      "QueueName": "#{RABBITMQ_QUEUE_NAME}#"
    }
  },
  "HealthChecks": {
    "Enabled": true,
    "DetailedErrors": false
  },
  "RateLimiting": {
    "DocumentUpload": {
      "PermitLimit": 10,
      "WindowMinutes": 1
    },
    "Search": {
      "PermitLimit": 100,
      "WindowMinutes": 1
    }
  },
  "ApplicationInsights": {
    "InstrumentationKey": "#{APPLICATION_INSIGHTS_INSTRUMENTATION_KEY}#",
    "ConnectionString": "#{APPLICATION_INSIGHTS_CONNECTION_STRING}#"
  }
}