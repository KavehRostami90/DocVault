# Copy this file to .env and fill in your values before running docker compose.
# .env is gitignored — never commit it.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DOCVAULT_DB_NAME=docvault
DOCVAULT_DB_USER=docvault
DOCVAULT_DB_PASSWORD=change-me

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing key — must be at least 32 characters (use a random secret).
DOCVAULT_JWT_KEY=change-me-to-a-long-random-secret-at-least-32-chars

# Admin account created on first startup.
DOCVAULT_ADMIN_EMAIL=admin@example.com
DOCVAULT_ADMIN_PASSWORD=change-me

# ── Ports (change if 3000 or 8080 are already in use) ────────────────────────
DOCVAULT_UI_PORT=3000
DOCVAULT_API_PORT=8080

# ── Uploads ───────────────────────────────────────────────────────────────────
# Maximum file size in bytes (default: 50 MB).
DOCVAULT_UPLOAD_MAX_FILE_SIZE_BYTES=52428800

# ── Embedding provider ────────────────────────────────────────────────────────
#
# Option A — Ollama running natively on your host machine (recommended for dev):
#   Install Ollama from https://ollama.com, then run: ollama pull nomic-embed-text
#   The api container reaches it via host.docker.internal automatically.
#
DOCVAULT_OPENAI_BASE_URL=http://host.docker.internal:11434/v1
DOCVAULT_OPENAI_API_KEY=ollama
DOCVAULT_OPENAI_MODEL=nomic-embed-text
# Set to 0 to use the model's native output size (required for Ollama).
# Use a positive value only for OpenAI models that support the "dimensions"
# parameter (e.g. text-embedding-3-small → 1536).
DOCVAULT_OPENAI_DIMENSIONS=0

# Option B — Ollama as a Docker Compose service (start with --profile ollama):
#
# DOCVAULT_OPENAI_BASE_URL=http://ollama:11434/v1
# DOCVAULT_OPENAI_API_KEY=ollama
# DOCVAULT_OPENAI_MODEL=nomic-embed-text
# DOCVAULT_OPENAI_DIMENSIONS=0

# Model that ollama-init will pull when using the ollama profile.
DOCVAULT_OLLAMA_MODEL=nomic-embed-text

# Option C — Real OpenAI API:
#
# DOCVAULT_OPENAI_BASE_URL=https://api.openai.com/v1
# DOCVAULT_OPENAI_API_KEY=sk-...
# DOCVAULT_OPENAI_MODEL=text-embedding-3-small
# DOCVAULT_OPENAI_DIMENSIONS=1536

# ── QA / chat model ───────────────────────────────────────────────────────────
# Model used for question answering. Must be a chat-completions-compatible model.
# Pull on host:  ollama pull llama3.1
# Lighter alternatives: llama3.2 (~2 GB), mistral, phi3
DOCVAULT_QA_MODEL=llama3.1
