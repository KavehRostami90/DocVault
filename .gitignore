# Build output
bin/
obj/

# IDE
.vs/
.vscode/
*.user
*.suo
*.DS_Store
*.swp

# Test results & coverage
TestResults/
coverage/
*.trx
*.coverage
*.coveragexml

# Serilog rolling logs
**/Logs/
**/logs/
*.log
*.clef

# Secrets & local environment
# .env.local and .env.*.local are machine-specific overrides — never commit them.
# .env.production (non-secret Vite vars) is intentionally tracked.
# .env at root holds Docker Compose secrets — never commit.
.env
.env.local
.env.*.local
secrets/
appsettings.Development.json
appsettings.*.Local.json

# Bicep/azd local parameter overrides (may contain real secrets)
infra/*.parameters.local.json
.azure/

# Docker local overrides
docker-compose.override.yml

# Azurite local storage (Azure Storage emulator)
__blobstorage__/
__queuestorage__/
__azurite_db_table__.json
AzuriteConfig

# UI — dependencies, build output, and TS incremental build cache
ui/node_modules/
ui/dist/
ui/*.tsbuildinfo

# Directory placeholders — never commit
.gitkeep

# Claude Code — local settings and project instructions are machine-specific
CLAUDE.md
.claude/settings.local.json

# GitHub Copilot — local instructions and settings are machine-specific
.github/copilot-instructions.md
.copilot/
