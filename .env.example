# Copy this file to .env and fill in your values before running docker compose.
# .env is gitignored — never commit it.

# PostgreSQL credentials (used by both the db and api containers)
DOCVAULT_DB_NAME=docvault
DOCVAULT_DB_USER=docvault
DOCVAULT_DB_PASSWORD=change-me

# JWT signing key — must be at least 32 characters
DOCVAULT_JWT_KEY=change-me-to-a-long-random-secret!!

# Admin account seeded on first startup
DOCVAULT_ADMIN_EMAIL=admin@example.com
DOCVAULT_ADMIN_PASSWORD=change-me

# ── Embedding provider ────────────────────────────────────────────────────────
#
# Option A — Ollama running natively on your host machine (default for dev):
#   Install Ollama from https://ollama.com, then: ollama pull nomic-embed-text
#   The api container reaches it via host.docker.internal automatically.
#
DOCVAULT_OPENAI_BASE_URL=http://host.docker.internal:11434/v1
DOCVAULT_OPENAI_API_KEY=ollama
DOCVAULT_OPENAI_MODEL=nomic-embed-text
# Set to 0 to use the model's native output size (required for Ollama — it does
# not support dimension truncation). Use a positive value only for OpenAI models
# that explicitly support the "dimensions" parameter (e.g. text-embedding-3-*).
DOCVAULT_OPENAI_DIMENSIONS=0

# Option B — Ollama as a Docker Compose service (on-prem / self-hosted):
#   docker compose --profile ollama run --rm ollama-init   # pull model once
#   docker compose --profile ollama up
#   Then set the base URL to the container name:
#
# DOCVAULT_OPENAI_BASE_URL=http://ollama:11434/v1
# DOCVAULT_OPENAI_API_KEY=ollama
# DOCVAULT_OPENAI_MODEL=nomic-embed-text
# DOCVAULT_OPENAI_DIMENSIONS=0

# Model that ollama-init will pull (used by the init container in the ollama profile).
DOCVAULT_OLLAMA_MODEL=nomic-embed-text

# Option C — Real OpenAI API:
#
# DOCVAULT_OPENAI_BASE_URL=https://api.openai.com/v1
# DOCVAULT_OPENAI_API_KEY=sk-...
# DOCVAULT_OPENAI_MODEL=text-embedding-3-small
# DOCVAULT_OPENAI_DIMENSIONS=1536

# ── Blob storage ──────────────────────────────────────────────────────────────
# Leave empty to use local-disk storage inside the container (default).
#
# To use Azurite (Azure Storage emulator):
#   docker compose --profile azurite up
#   Then uncomment the line below. The AccountKey is Azurite's public well-known
#   dev credential — it is NOT a secret.
#
# DOCVAULT_BLOB_CONN_STR=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;
#
# For a real Azure Storage account:
# DOCVAULT_BLOB_CONN_STR=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
