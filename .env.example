# Copy this file to .env and fill in your values before running docker compose.
# .env is gitignored — never commit it.

# PostgreSQL credentials (used by both the db and api containers)
DOCVAULT_DB_NAME=docvault
DOCVAULT_DB_USER=docvault
DOCVAULT_DB_PASSWORD=change-me

# JWT signing key — must be at least 32 characters
DOCVAULT_JWT_KEY=change-me-to-a-long-random-secret!!

# Admin account seeded on first startup
DOCVAULT_ADMIN_EMAIL=admin@example.com
DOCVAULT_ADMIN_PASSWORD=change-me

# OpenAI / Ollama — used only for local Docker Compose (not in production).
# Point BASE_URL at your local Ollama instance; API_KEY can be any non-empty string for Ollama.
DOCVAULT_OPENAI_BASE_URL=http://host.docker.internal:11434/v1
DOCVAULT_OPENAI_API_KEY=ollama
DOCVAULT_OPENAI_MODEL=nomic-embed-text
DOCVAULT_OPENAI_DIMENSIONS=0
